tsconfig.build.json
next.config.ts
next-env.d.ts
eslint.config.mjs
postcss.config.mjs
Dockerfile
docker-compose.yml

# Data and secrets
data/
*.gai
*.db
*.db-*
.env
.env.*

# Dev tooling
.claude/
.git/
.github/
.gitignore
.vscode/
.idea/
