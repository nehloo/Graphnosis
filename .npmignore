# The `files` field in package.json is the allowlist; this is a belt-and-braces
# denylist so a mis-edit there can't leak app code, tests, or data.

# App + non-SDK source
src/app/
src/examples/
src/mcp/
public/
docs/
benchmarks/
enterprise/
tests/

# Build + config
.next/
.turbo/
coverage/
